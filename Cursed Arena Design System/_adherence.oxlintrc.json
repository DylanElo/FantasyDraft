{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/cards/**",
              "components/core/**",
              "components/feedback/**",
              "components/game-hud/**",
              "components/navigation/**",
              "components/overlay/**",
              "exports/**",
              "ui_kits/mobile-app-v2/**",
              "ui_kits/mobile-app/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Lilita One|Inter|JetBrains Mono|Yuji Mai))/i]",
        "message": "Font not provided by the design system. Available: Lilita One, Inter, JetBrains Mono, Yuji Mai."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, tone."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|curse|gold|teal|red)$/]",
        "message": "<Badge> tone must be one of 'neutral' | 'curse' | 'gold' | 'teal' | 'red'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|disabled|icon|fullWidth|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, disabled, icon, fullWidth, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|gold|secondary|ghost|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'gold' | 'secondary' | 'ghost' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|faction|rarity|portraitUrl|selected|onClick|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: name, faction, rarity, portraitUrl, selected, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='rarity'] > Literal[value!=/^(?:common|rare|epic|legendary|mythic)$/]",
        "message": "<Card> rarity must be one of 'common' | 'rare' | 'epic' | 'legendary' | 'mythic'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CurrencyPill'] > JSXAttribute > JSXIdentifier[name!=/^(?:kind|amount|onAdd|key|ref|className|style|children)$/]",
        "message": "<CurrencyPill> doesn't accept that prop. Declared props: kind, amount, onAdd."
      },
      {
        "selector": "JSXOpeningElement[name.name='CurrencyPill'] > JSXAttribute[name.name='kind'] > Literal[value!=/^(?:gold|gem)$/]",
        "message": "<CurrencyPill> kind must be one of 'gold' | 'gem'."
      },
      {
        "selector": "JSXOpeningElement[name.name='EnergyPip'] > JSXAttribute > JSXIdentifier[name!=/^(?:type|filled|size|key|ref|className|style|children)$/]",
        "message": "<EnergyPip> doesn't accept that prop. Declared props: type, filled, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='EnergyPip'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:B|T|F|C|X)$/]",
        "message": "<EnergyPip> type must be one of 'B' | 'T' | 'F' | 'C' | 'X'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|size|active|onClick|style|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: children, size, active, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|max|tone|lagValue|height|key|ref|className|style|children)$/]",
        "message": "<ProgressBar> doesn't accept that prop. Declared props: value, max, tone, lagValue, height."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressBar'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:hp|danger|xp|energy)$/]",
        "message": "<ProgressBar> tone must be one of 'hp' | 'danger' | 'xp' | 'energy'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Sheet'] > JSXAttribute > JSXIdentifier[name!=/^(?:open|title|children|onClose|key|ref|className|style|children)$/]",
        "message": "<Sheet> doesn't accept that prop. Declared props: open, title, children, onClose."
      },
      {
        "selector": "JSXOpeningElement[name.name='SkillCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|cost|cooldown|effect|state|onClick|key|ref|className|style|children)$/]",
        "message": "<SkillCard> doesn't accept that prop. Declared props: name, cost, cooldown, effect, state, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='SkillCard'] > JSXAttribute[name.name='state'] > Literal[value!=/^(?:ready|cooldown|energy|stunned)$/]",
        "message": "<SkillCard> state must be one of 'ready' | 'cooldown' | 'energy' | 'stunned'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TabBarTab'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|label|icon|hero|key|ref|className|style|children)$/]",
        "message": "<TabBarTab> doesn't accept that prop. Declared props: id, label, icon, hero."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute > JSXIdentifier[name!=/^(?:message|tone|key|ref|className|style|children)$/]",
        "message": "<Toast> doesn't accept that prop. Declared props: message, tone."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:info|success|warning|danger)$/]",
        "message": "<Toast> tone must be one of 'info' | 'success' | 'warning' | 'danger'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
